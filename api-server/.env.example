# SQL Server 接続情報
DB_SERVER=your-internal-sql-server-host
DB_PORT=1433
DB_DATABASE=your-database-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# このAPIを呼び出す側(Apps Script)が送ってくる認証キー。
# openssl rand -hex 32 などで生成した、推測されにくい文字列を設定してください。
API_KEY=change-me-to-a-random-secret

# APIサーバーのポート
PORT=3000

# 出願文書サーバー(社内LAN限定)のURLプレフィックス。例: http://hostname:111
DOC_SERVER_URL_PREFIX=http://your-doc-server-host:111
